<Page
    x:Class="JitHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.Views"
    xmlns:viewmodels="using:JitHub.ViewModels"
    xmlns:uc="using:JitHub.Views.Controls"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:widget="using:JitHub.Widget"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:widgets="using:JitHub.Views.Controls.Widgets"
    mc:Ignorable="d"
    Background="Transparent">
    <Page.DataContext>
        <viewmodels:DashboardViewModel x:Name="ViewModel"/>
    </Page.DataContext>
    <Grid
        Padding="20">
        <winui:ItemsRepeaterScrollHost>
            <ScrollViewer>
                <winui:ItemsRepeater
                    x:Name="WidgetsHost"
                    ItemsSource="{x:Bind ViewModel.Widgets, Mode=OneWay}">
                    <winui:ItemsRepeater.Layout>
                        <widget:WidgetLayout
                            x:Name="WidgetLayoutRef"
                            EnableDiagnostics="True"
                            Columns="3"
                            MinColumns="1"
                            HorizontalMode="Center"
                            ColumnWidth="320"
                            RowHeight="480"
                            Spacing="12"
                            ReflowAnimationDuration="450"
                            StandardAnimationDuration="180"
                            IsEditing="{x:Bind ViewModel.IsWidgetEditMode, Mode=OneWay}"
                            ReorderRequested="{x:Bind ViewModel.WidgetsReorderRequested, Mode=OneWay}"/>
                    </winui:ItemsRepeater.Layout>
                    <winui:ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- Root changed to WidgetContainer so GetElementIndex works for drag -->
                            <widget:WidgetContainer
                                Layout="{Binding ElementName=WidgetLayoutRef}"
                                Style="{ThemeResource PlainContainer}">
                                <widgets:WidgetPresenter
                                    Data="{Binding Self, Mode=OneWay}"/>
                            </widget:WidgetContainer>
                        </DataTemplate>
                    </winui:ItemsRepeater.ItemTemplate>
                </winui:ItemsRepeater>
            </ScrollViewer>
        </winui:ItemsRepeaterScrollHost>
    </Grid>
</Page>
