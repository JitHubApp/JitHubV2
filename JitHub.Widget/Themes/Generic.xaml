<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.Widget">

    <Style TargetType="local:WidgetContainer" >
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:WidgetContainer">
                    <Border
                        x:Name="ContainerBorder"
                        Style="{TemplateBinding Style}"
                        Background="{ThemeResource ExpanderContentBackground}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        Width="Auto"
                        Height="Auto"
                        Padding="12"
                        CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header (drag surface). Expanded height and full width so user can easily grab it. -->
                            <Grid x:Name="Header"
                                  Grid.Row="0"
                                  Background="Transparent"
                                  Opacity="0"
                                  IsHitTestVisible="False"
                                  Height="16">
                                <StackPanel
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                                    <Rectangle x:Name="DragHandle"
                                               Width="32"
                                               Height="6"
                                               RadiusX="3" RadiusY="3"
                                               Fill="Gray"
                                               Opacity="0.8"/>
                                    <!-- Optional label shown only during editing (so user sees drag affordance). We bind to Tag (if any) for minimal impact. -->
                                </StackPanel>
                            </Grid>
                            <!-- Single ContentPresenter hosting the control's Content -->
                            <ContentPresenter Grid.Row="1" Content="{TemplateBinding Content}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
