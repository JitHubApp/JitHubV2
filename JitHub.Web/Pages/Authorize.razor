@page "/authorize"

<PageTitle>Authorize | JitHub</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="auth-page">
    <div class="auth-card surface-card" data-auth-root data-token-endpoint="/api/GithubCodeToToken">
        <p class="eyebrow">GitHub Sign-In</p>

        <div class="auth-state" data-auth-state="loading">
            <div class="auth-spinner" aria-hidden="true"></div>
            <h1>Finishing sign-in</h1>
            <p>
                We are exchanging the temporary GitHub approval code and sending the result back to the desktop app.
            </p>
        </div>

        <div class="auth-state" data-auth-state="success" hidden>
            <img class="auth-illustration" src="login_success.svg" alt="" />
            <h1>Authorization successful</h1>
            <p>
                JitHub should open automatically. If your browser stays here, use the button below to hand control back.
            </p>
            <div class="button-row">
                <a class="button button--primary" data-auth-launch href="jithub://">Open JitHub</a>
                <a class="button button--ghost" href="/">Back to site</a>
            </div>
        </div>

        <div class="auth-state" data-auth-state="failed" hidden>
            <img class="auth-illustration" src="login_fail.svg" alt="" />
            <h1>We could not complete sign-in</h1>
            <p data-auth-error>
                Try handing control back to the app and starting the GitHub login flow one more time.
            </p>
            <div class="button-row">
                <a class="button button--primary" href="jithub://">Return to JitHub</a>
                <a class="button button--ghost" href="/">Back to site</a>
            </div>
        </div>
    </div>
</section>

<script type="module" src="js/authorize.js"></script>
