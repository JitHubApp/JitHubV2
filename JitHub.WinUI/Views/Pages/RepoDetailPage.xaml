<Page
    x:Class="JitHub.WinUI.Views.Pages.RepoDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.WinUI.Views.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:repoviewmodels="using:JitHub.WinUI.ViewModels.RepositoryViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:appcontrols="using:JitHub.WinUI.Views.Controls.App"
    Background="Transparent">
    <Page.DataContext>
        <repoviewmodels:RepoDetailViewModel x:Name="ViewModel"/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <muxc:NavigationView
            Style="{StaticResource PullRequestNavigationViewStyle}"
            IsBackButtonVisible="Collapsed"
            BackRequested="{x:Bind ViewModel.RepoDetailNav_BackRequested}"
            ItemInvoked="{x:Bind ViewModel.RepoDetailNav_ItemInvoked}"
            MenuItemsSource="{x:Bind ViewModel.MenuItems, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            IsSettingsVisible="False"
            Grid.Row="1"
            x:Name="RepoDetailNav"
            PaneDisplayMode="Top">
            <muxc:NavigationView.PaneCustomContent>
                <Grid
                    Padding="0 0 16 0"
                    HorizontalAlignment="Stretch">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                        <muxc:ProgressRing
                            VerticalAlignment="Center"
                            IsActive="True"
                            Height="16"
                            Width="16"
                            Visibility="{x:Bind ViewModel.Loading, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                        <ComboBox
                            Style="{StaticResource ComboBox}"
                            Visibility="{x:Bind ViewModel.BranchVisible, Mode=OneWay}"
                            MinWidth="150"
                            AutomationProperties.AutomationId="RepoDetailBranchPicker"
                            ItemsSource="{x:Bind ViewModel.Branches, Mode=OneWay}"
                            DisplayMemberPath="Name"
                            SelectionChanged="{x:Bind ViewModel.BranchSelectionChanged, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedBranch, Mode=OneWay}" />
                        <appcontrols:AppStatButton
                            AutomationId="RepoDetailWatchButton"
                            Command="{x:Bind ViewModel.ToggleWatchCommand, Mode=OneWay}"
                            IconKind="Watch"
                            IconForeground="{ThemeResource AppInkMutedBrush}"
                            IsSelected="{x:Bind ViewModel.IsWatching, Mode=OneWay}"
                            SelectedIconForeground="{ThemeResource AppAccentBrush}"
                            ValueText="{x:Bind ViewModel.Model.SubscribersCount, Converter={StaticResource NumberToKizedStringConverter}, Mode=OneWay}" />
                        <appcontrols:AppStatButton
                            AutomationId="RepoDetailStarButton"
                            Command="{x:Bind ViewModel.ToggleStarCommand, Mode=OneWay}"
                            IconKind="Star"
                            IconForeground="{ThemeResource AppInkMutedBrush}"
                            IsSelected="{x:Bind ViewModel.IsStarred, Mode=OneWay}"
                            SelectedIconForeground="{ThemeResource AppWarmAccentBrush}"
                            ValueText="{x:Bind ViewModel.Model.StargazersCount, Converter={StaticResource NumberToKizedStringConverter}, Mode=OneWay}" />
                        <appcontrols:AppStatButton
                            AutomationId="RepoDetailForkButton"
                            Command="{x:Bind ViewModel.ForkCommand, Mode=OneWay}"
                            IconKind="Fork"
                            IconForeground="{ThemeResource AppInkMutedBrush}"
                            ValueText="{x:Bind ViewModel.Model.ForksCount, Converter={StaticResource NumberToKizedStringConverter}, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </muxc:NavigationView.PaneCustomContent>
            <Frame x:Name="RepoDetailFrame"/>
        </muxc:NavigationView>
    </Grid>
</Page>



