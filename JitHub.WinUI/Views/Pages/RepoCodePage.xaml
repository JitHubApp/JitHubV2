<Page
    x:Class="JitHub.WinUI.Views.Pages.RepoCodePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:cv="using:JitHub.WinUI.Views.Controls.CodeViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="RootGrid" MinHeight="700">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppOutlineBrush}"
                BorderThickness="0,0,1,0">
            <cv:RepoFileTreeView x:Name="FileTree"
                                 DataContext="{x:Bind ViewModel.Tree, Mode=OneWay}" />
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <cv:RepoCodeBreadcrumb x:Name="Breadcrumb"
                                   Grid.Row="0"
                                   DataContext="{x:Bind ViewModel.Breadcrumb, Mode=OneWay}"
                                   GoBackCommand="{x:Bind ViewModel.GoBackCommand, Mode=OneWay}"
                                   GoForwardCommand="{x:Bind ViewModel.GoForwardCommand, Mode=OneWay}"
                                   CanGoBack="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                                   CanGoForward="{x:Bind ViewModel.CanGoForward, Mode=OneWay}" />

            <cv:FilePreviewHost x:Name="PreviewHost"
                                Grid.Row="1"
                                DataContext="{x:Bind ViewModel.Preview, Mode=OneWay}" />
        </Grid>

        <muxc:ProgressRing x:Name="LoadingIndicator"
                           Grid.ColumnSpan="2"
                           IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                           Width="50"
                           Height="50"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

        <Border x:Name="ErrorBanner"
                Grid.ColumnSpan="2"
                MaxWidth="520"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppOutlineBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource AppRadiusLarge}"
                Visibility="Collapsed">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                           Text="Couldn't load this repository's code." />
                <TextBlock x:Name="ErrorMessageText"
                           Style="{StaticResource SectionSecondaryTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
