<Page
    x:Class="JitHub.WinUI.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.WinUI.Views.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:JitHub.WinUI.ViewModels"
    xmlns:common="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:appcontrols="using:JitHub.WinUI.Views.Controls.App"
    mc:Ignorable="d"
    Background="Transparent">
    <Page.DataContext>
        <viewmodels:SettingsViewModel x:Name="ViewModel"/>
    </Page.DataContext>
    <Grid
        Padding="{ThemeResource AppPagePadding}"
        AutomationProperties.AutomationId="SettingsRoot">
        <ScrollViewer>
            <Grid
                MaxWidth="{ThemeResource AppReadablePageMaxWidth}"
                HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                <appcontrols:AppSectionHeader
                    Eyebrow="PREFERENCES"
                    Title="Settings"
                    Description="Quiet defaults, practical controls, and a cleaner reading rhythm across the app." />

                <appcontrols:AppSettingsCard
                    Header="Theme"
                    Description="Set app theme to light, dark or follow Windows system theme.">
                    <appcontrols:AppSettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE790;" />
                    </appcontrols:AppSettingsCard.HeaderIcon>
                    <appcontrols:AppSettingsCard.ActionContent>
                        <ComboBox
                            AutomationProperties.AutomationId="SettingsThemeComboBox"
                            Style="{StaticResource ComboBox}"
                            Width="160"
                            SelectionChanged="{x:Bind ViewModel.SelectionChanged, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                            ItemsSource="{x:Bind ViewModel.Themes, Mode=OneWay}" />
                    </appcontrols:AppSettingsCard.ActionContent>
                </appcontrols:AppSettingsCard>

                <appcontrols:AppSettingsCard
                    Header="Developer Mode"
                    Description="This will enable developer mode where some debug features are turned on.">
                    <appcontrols:AppSettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC7A;" />
                    </appcontrols:AppSettingsCard.HeaderIcon>
                    <appcontrols:AppSettingsCard.ActionContent>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.GlobalViewModel.DevMode, Mode=TwoWay}" />
                    </appcontrols:AppSettingsCard.ActionContent>
                </appcontrols:AppSettingsCard>

                <appcontrols:AppSettingsCard
                    Header="JitHub Version"
                    Description="{x:Bind ViewModel.Version, Mode=OneWay}">
                    <appcontrols:AppSettingsCard.HeaderIcon>
                        <Image
                            Width="20"
                            Height="20"
                            Stretch="Uniform"
                            Source="ms-appx:///Assets/JitHubLogo.png" />
                    </appcontrols:AppSettingsCard.HeaderIcon>
                    <appcontrols:AppSettingsCard.ActionContent>
                        <Button
                            Click="{x:Bind ViewModel.ViewJitHubCode, Mode=OneWay}"
                            Style="{StaticResource AppAccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <common:ThemeImage
                                    IconWidth="24"
                                    IconHeight="24"
                                    DarkSource="ms-appx:///Assets/Icons/github_logo_dark.png"
                                    LightSource="ms-appx:///Assets/Icons/github_logo_light.png" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="View Source Code" />
                            </StackPanel>
                        </Button>
                    </appcontrols:AppSettingsCard.ActionContent>
                </appcontrols:AppSettingsCard>

                <appcontrols:AppSectionHeader
                    Eyebrow="PEOPLE"
                    Title="Credits"
                    Description="Designed and built with a small crew and a lot of care." />

                <appcontrols:AppSurfaceCard CardPadding="20">
                    <appcontrols:AppSurfaceCard.Child>
                        <StackPanel Spacing="16">
                            <appcontrols:AppSectionHeader
                                Title="Developers"
                                Description="Core app, migration, and infrastructure work." />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12">
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.Nero, Mode=OneWay}" />
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.Get, Mode=OneWay}" />
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.ZyC, Mode=OneWay}" />
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.Xueyang, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </appcontrols:AppSurfaceCard.Child>
                </appcontrols:AppSurfaceCard>

                <appcontrols:AppSurfaceCard CardPadding="20">
                    <appcontrols:AppSurfaceCard.Child>
                        <StackPanel Spacing="16">
                            <appcontrols:AppSectionHeader
                                Title="Designers"
                                Description="Interface thinking, icon direction, and polish." />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12">
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.Keira, Mode=OneWay}" />
                                <common:CreditPersonaleButton Person="{x:Bind ViewModel.Jakub, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </appcontrols:AppSurfaceCard.Child>
                </appcontrols:AppSurfaceCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

