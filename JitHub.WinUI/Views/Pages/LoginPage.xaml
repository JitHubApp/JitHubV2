<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JitHub.WinUI.Views.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appcontrols="using:JitHub.WinUI.Views.Controls.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodels="using:JitHub.WinUI.ViewModels.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="viewmodels:LoginPageViewModel"
    mc:Ignorable="d">
    <Grid
        AutomationProperties.AutomationId="LoginRoot"
        Padding="{ThemeResource AppPagePadding}"
        Background="{ThemeResource AppCanvasBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="{ThemeResource AppLoginPageMaxWidth}"
                Margin="0,40,0,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel
                    MaxWidth="760"
                    Spacing="24"
                    VerticalAlignment="Center">
                    <StackPanel
                        MaxWidth="640"
                        Spacing="0">
                        <TextBlock
                            Style="{StaticResource PageTitleTextBlockStyle}"
                            Text="{Binding AppTitle}" />
                    </StackPanel>

                    <appcontrols:AppSurfaceCard
                        MaxWidth="460"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="LoginCard">
                        <appcontrols:AppSurfaceCard.Child>
                            <StackPanel Spacing="16">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextBlockStyle}"
                                    Text="{Binding SignInTitle}" />
                                <TextBlock
                                    Style="{StaticResource SectionSecondaryTextBlockStyle}"
                                    Text="{Binding StatusText}"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    Click="LoginButton_Click"
                                    IsEnabled="{Binding IsLoginEnabled}"
                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <FontIcon Glyph="&#xE72E;" />
                                        <TextBlock Text="{Binding ContinueWithGitHubButtonText}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </appcontrols:AppSurfaceCard.Child>
                    </appcontrols:AppSurfaceCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
