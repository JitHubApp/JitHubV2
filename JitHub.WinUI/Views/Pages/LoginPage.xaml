<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JitHub.WinUI.Views.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodels="using:JitHub.WinUI.ViewModels.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="viewmodels:LoginPageViewModel"
    mc:Ignorable="d">
    <Grid Padding="32">
        <Grid
            MaxWidth="1100"
            ColumnSpacing="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                MaxWidth="560"
                Spacing="16"
                VerticalAlignment="Center">
                <TextBlock
                    Style="{StaticResource PageTitleTextBlockStyle}"
                    Text="{Binding AppTitle}" />
                <TextBlock
                    Style="{StaticResource SectionTitleTextBlockStyle}"
                    Text="{Binding HeroTitle}" />
                <TextBlock
                    Style="{StaticResource SectionBodyTextBlockStyle}"
                    Text="{Binding HeroDescription}" />
                <TextBlock
                    Style="{StaticResource SectionSecondaryTextBlockStyle}"
                    Text="{Binding CallbackDescription}" />
            </StackPanel>

            <Border
                Grid.Column="1"
                MaxWidth="420"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Padding="24"
                Style="{StaticResource SectionCardBorderStyle}"
                CornerRadius="16">
                <StackPanel Spacing="16">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextBlockStyle}"
                        Text="{Binding SignInTitle}" />
                    <TextBlock
                        Style="{StaticResource SectionSecondaryTextBlockStyle}"
                        Text="{Binding StatusText}" />
                    <Button
                        Click="LoginButton_Click"
                        IsEnabled="{Binding IsLoginEnabled}"
                        Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <FontIcon Glyph="&#xE72E;" />
                            <TextBlock Text="{Binding ContinueWithGitHubButtonText}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
