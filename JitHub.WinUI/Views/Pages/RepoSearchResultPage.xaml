<Page
    x:Class="JitHub.WinUI.Views.Pages.RepoSearchResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.WinUI.Views.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:repositoryviewmodels="using:JitHub.WinUI.ViewModels.RepositoryViewModels"
    xmlns:helpers="using:JitHub.WinUI.Helpers"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">
    <Page.DataContext>
        <repositoryviewmodels:RepoSearchResultViewModel x:Name="ViewModel"/>
    </Page.DataContext>
    <Page.Resources>
        <helpers:RepoIconTemplateSelector
            x:Key="RepoTemplate"
            PublicTemplate="{StaticResource PublicRepoSearchResult}"
            PrivateTemplate="{StaticResource PrivateRepoSearchResult}"
            ForkTemplate="{StaticResource ForkRepoSearchResult}"/>
    </Page.Resources>
    <Grid>
        <muxc:ProgressRing
            IsActive="True"
            Height="50"
            Width="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.Loading, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
        <ScrollViewer
            Padding="10">
            <muxc:ItemsRepeater
                ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                ItemTemplate="{StaticResource RepoTemplate}">
                <muxc:ItemsRepeater.Layout>
                    <muxc:StackLayout Spacing="8"/>
                </muxc:ItemsRepeater.Layout>
            </muxc:ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>

