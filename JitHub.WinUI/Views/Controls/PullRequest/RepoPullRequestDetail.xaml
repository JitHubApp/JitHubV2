<UserControl
    x:Class="JitHub.WinUI.Views.Controls.PullRequest.RepoPullRequestDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.WinUI.Views.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid
            Grid.Row="0"
            Padding="8 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height=" *"/>
            </Grid.RowDefinitions>
            <Grid
                Grid.Row="0"
                HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource SectionTitleTextBlockStyle}"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap">
                    <Run
                        Text="{x:Bind ViewModel.PullRequest.Title, Mode=OneWay}"/>
                    <Run
                        Foreground="{ThemeResource AppInkMutedBrush}"
                        Text="{x:Bind ViewModel.PullRequest.Number, Converter={StaticResource NumberToHashTaggedStringConverter}, Mode=OneWay}"/>
                </TextBlock>
                <Button
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource AppToolbarButtonStyle}"
                    Command="{x:Bind ViewModel.EditCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsAuthor, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    Edit
                </Button>
            </Grid>
            <Grid
                Grid.Row="1"
                Padding="0 0 0 4"
                BorderBrush="{ThemeResource AppOutlineBrush}"
                BorderThickness="0 0 0 1">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4">
                    <Border
                        Margin="0 0 4 0"
                        CornerRadius="{ThemeResource AppRadiusSmall}"
                        Height="24"
                        MinWidth="48"
                        Padding="8 0"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Background="{x:Bind GetStateBackgroundBrush(ViewModel.PullRequest.State), Mode=OneWay}">
                        <TextBlock
                            Style="{StaticResource AppStatusPillTextBlockStyle}"
                            Text="{x:Bind ViewModel.PullRequest.State.StringValue, Mode=OneWay}"/>
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource SectionSecondaryTextBlockStyle}"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource AppInkMutedBrush}">
                        <Run
                            Text="{x:Bind ViewModel.PullRequest.User.Login, Mode=OneWay}"/>
                        <Run
                            Text="{x:Bind ViewModel.PullRequest.CreatedAt, Converter={StaticResource OpenDateToStringForDetailConverter}, ConverterParameter=pull&#160;request, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
        <muxc:NavigationView
            Grid.Row="1"
            x:Name="RepoPullRequestDetailNavView"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="Top"
            IsSettingsVisible="False"
            Style="{StaticResource PullRequestNavigationViewStyle}"
            BackRequested="{x:Bind ViewModel.RepoPullRequestDetailNavView_BackRequested}"
            ItemInvoked="{x:Bind ViewModel.RepoPullRequestDetailNavView_ItemInvoked}">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Conversation" Tag="Conversation" IsSelected="True"/>
                <muxc:NavigationViewItem Content="Commits" Tag="Commits"/>
            </muxc:NavigationView.MenuItems>
            <Frame
                x:Name="RepoPullRequestDetailFrame"/>
        </muxc:NavigationView>
    </Grid>
</UserControl>

