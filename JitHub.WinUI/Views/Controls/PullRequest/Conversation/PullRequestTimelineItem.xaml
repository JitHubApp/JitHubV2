<UserControl
    x:Class="JitHub.WinUI.Views.Controls.PullRequest.Conversation.PullRequestTimelineItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:activities="using:JitHub.Models.Activities"
    xmlns:common="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PullRequestTimelineInlineLinkForegroundBrush" Color="{ThemeResource AppAccentColor}" />
        <SolidColorBrush x:Key="PullRequestTimelineInlineLinkForegroundPointerOverBrush" Color="{ThemeResource AppAccentHoverColor}" />
        <SolidColorBrush x:Key="PullRequestTimelineInlineLinkForegroundPressedBrush" Color="{ThemeResource AppAccentPressedColor}" />
    </UserControl.Resources>

    <Border
        x:Name="TimelineCard"
        Padding="4,8"
        HorizontalAlignment="Stretch"
        Background="Transparent"
        BorderThickness="0">
        <Grid
            x:Name="Root"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <common:Avatar
                x:Name="ActorAvatar"
                Margin="0,2,0,0"
                VerticalAlignment="Top"
                ShowLogin="False"
                Size="SMALL" />

            <StackPanel
                Grid.Column="1"
                Spacing="7">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="IconBorder"
                        Width="25"
                        Height="25"
                        Margin="0,1,0,0"
                        VerticalAlignment="Top"
                        Background="{ThemeResource AppSurfaceBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource AppRadiusSmall}">
                        <FontIcon
                            x:Name="IconGlyph"
                            FontFamily="{StaticResource SegoeFluentIcons}"
                            FontSize="12" />
                    </Border>

                    <RichTextBlock
                        x:Name="SentenceRichTextBlock"
                        Grid.Column="1"
                        FontFamily="{ThemeResource AppUiFontFamily}"
                        FontSize="15"
                        Foreground="{ThemeResource AppInkBrush}"
                        IsTextSelectionEnabled="False"
                        LineHeight="24"
                        TextWrapping="WrapWholeWords" />
                </Grid>

                <TextBlock
                    x:Name="TimestampTextBlock"
                    Margin="33,-4,0,0"
                    Style="{StaticResource SectionSecondaryTextBlockStyle}" />

                <Border
                    x:Name="DetailsBorder"
                    Margin="33,0,0,0"
                    Padding="10,0,0,0"
                    BorderThickness="2,0,0,0"
                    Visibility="Collapsed">
                    <ItemsControl x:Name="DetailsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="activities:ActivityCardDetailViewModel">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Margin="0,2,0,0"
                                        VerticalAlignment="Top"
                                        FontFamily="{StaticResource SegoeFluentIcons}"
                                        FontSize="11"
                                        Foreground="{ThemeResource AppInkMutedBrush}"
                                        Glyph="{x:Bind Glyph, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource SectionSecondaryTextBlockStyle}"
                                        Text="{x:Bind Text, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
