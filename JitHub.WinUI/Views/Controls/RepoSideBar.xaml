<UserControl
    x:Class="JitHub.WinUI.Views.Controls.RepoSideBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:JitHub.Models.Base"
    xmlns:helpers="using:JitHub.WinUI.Helpers"
    xmlns:models="using:JitHub.Models"
    xmlns:appcontrols="using:JitHub.WinUI.Views.Controls.App"
    xmlns:local="using:JitHub.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:repoviewmodels="using:JitHub.WinUI.ViewModels.RepositoryViewModels"
    d:DesignHeight="300"
    d:DesignWidth="400"
    HorizontalAlignment="Stretch"
    Loaded="RepoSideBar_Loaded"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <repoviewmodels:RepoSideBarViewModel x:Name="ViewModel" />
    </UserControl.DataContext>
    <UserControl.Resources>
        <DataTemplate
            x:Key="SideBarPublicRepoTemplate"
            x:DataType="models:RepoModel">
            <Button
                Margin="0,0,4,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Command="{x:Bind DetailNavigationCommand, Mode=OneWay}"
                Style="{StaticResource AppQuietButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <appcontrols:AppIcon
                        VerticalAlignment="Center"
                        IconBrush="{ThemeResource AppInkMutedBrush}"
                        IconKind="PublicRepository"
                        IconSize="16" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate
            x:Key="SideBarPrivateRepoTemplate"
            x:DataType="models:RepoModel">
            <Button
                Margin="0,0,4,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Command="{x:Bind DetailNavigationCommand, Mode=OneWay}"
                Style="{StaticResource AppQuietButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <appcontrols:AppIcon
                        VerticalAlignment="Center"
                        IconBrush="{ThemeResource PrivateRepoBrush}"
                        IconKind="PrivateRepository"
                        IconSize="16" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate
            x:Key="SideBarForkRepoTemplate"
            x:DataType="models:RepoModel">
            <Button
                Margin="0,0,4,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Command="{x:Bind DetailNavigationCommand, Mode=OneWay}"
                Style="{StaticResource AppQuietButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <appcontrols:AppIcon
                        VerticalAlignment="Center"
                        IconBrush="{ThemeResource AppInkMutedBrush}"
                        IconKind="Fork"
                        IconSize="16" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </DataTemplate>
        <helpers:RepoIconTemplateSelector
            x:Key="SimpleRepoTemplate"
            ForkTemplate="{StaticResource SideBarForkRepoTemplate}"
            PrivateTemplate="{StaticResource SideBarPrivateRepoTemplate}"
            PublicTemplate="{StaticResource SideBarPublicRepoTemplate}" />
    </UserControl.Resources>
    <appcontrols:AppSidebarSection
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Title="Repositories">
        <appcontrols:AppSidebarSection.ActionContent>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Height="32"
                    AutomationProperties.AutomationId="RepoSideBarManage"
                    Click="{x:Bind ViewModel.OnManageRepo, Mode=OneWay}"
                    Style="{StaticResource AppToolbarButtonStyle}">
                    <muxc:AnimatedIcon x:Name="ManageRepoIcon">
                        <muxc:AnimatedIcon.Source>
                            <animatedvisuals:AnimatedSettingsVisualSource />
                        </muxc:AnimatedIcon.Source>
                        <muxc:AnimatedIcon.FallbackIconSource>
                            <muxc:SymbolIconSource Symbol="Setting" />
                        </muxc:AnimatedIcon.FallbackIconSource>
                    </muxc:AnimatedIcon>
                </Button>
                <Button
                    AutomationProperties.AutomationId="RepoSideBarNew"
                    Click="{x:Bind ViewModel.OnNewRepo, Mode=OneWay}"
                    Content="New"
                    Style="{StaticResource AppAccentButtonStyle}" />
            </StackPanel>
        </appcontrols:AppSidebarSection.ActionContent>
        <appcontrols:AppSidebarSection.BodyContent>
        <Grid
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <muxc:ProgressBar
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                IsIndeterminate="{x:Bind ViewModel.Loading, Mode=OneWay}"
                ShowError="False"
                ShowPaused="False"
                Visibility="{x:Bind ViewModel.Loading, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
            <controls1:Segmented
                Grid.Row="1"
                Margin="0,0,0,8"
                HorizontalAlignment="Stretch"
                SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"
                SelectionChanged="{x:Bind ViewModel.SegmentedSelectionChanged, Mode=OneWay}"
                SelectionMode="Single">
                <controls1:SegmentedItem Content="Public" />
                <controls1:SegmentedItem Content="Private" />
                <controls1:SegmentedItem Content="Forked" />
            </controls1:Segmented>
            <ScrollViewer
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsEmpty, Converter={StaticResource BoolToVisibilityReverseConverter}, Mode=OneWay}">
                <controls:SwitchPresenter TargetType="enum:RepoType" Value="{x:Bind ViewModel.RepositoryPublicity, Mode=OneWay}">
                    <controls:Case Value="Public">
                        <muxc:ItemsRepeater ItemTemplate="{StaticResource SimpleRepoTemplate}" ItemsSource="{x:Bind ViewModel.PublicRepos, Mode=OneWay}">
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Spacing="2" />
                            </muxc:ItemsRepeater.Layout>
                        </muxc:ItemsRepeater>
                    </controls:Case>
                    <controls:Case Value="Private">
                        <muxc:ItemsRepeater ItemTemplate="{StaticResource SimpleRepoTemplate}" ItemsSource="{x:Bind ViewModel.PrivateRepos, Mode=OneWay}">
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Spacing="2" />
                            </muxc:ItemsRepeater.Layout>
                        </muxc:ItemsRepeater>
                    </controls:Case>
                    <controls:Case Value="Forked">
                        <muxc:ItemsRepeater ItemTemplate="{StaticResource SimpleRepoTemplate}" ItemsSource="{x:Bind ViewModel.ForkedRepos, Mode=OneWay}">
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Spacing="2" />
                            </muxc:ItemsRepeater.Layout>
                        </muxc:ItemsRepeater>
                    </controls:Case>
                </controls:SwitchPresenter>
            </ScrollViewer>

        </Grid>
        </appcontrols:AppSidebarSection.BodyContent>
    </appcontrols:AppSidebarSection>
</UserControl>


