<UserControl
    x:Class="JitHub.WinUI.Views.Controls.App.AppSurfaceCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Background="{ThemeResource AppSurfaceBrush}"
        BorderBrush="{ThemeResource AppOutlineBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource AppRadiusLarge}"
        Padding="{Binding CardPadding, ElementName=Root}">
        <ContentPresenter Content="{Binding Child, ElementName=Root}" />
    </Border>
</UserControl>
