<UserControl
    x:Class="JitHub.WinUI.Views.Controls.App.AppSectionHeader"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid RowSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Spacing="4">
            <TextBlock
                Visibility="{Binding HasEyebrow, ElementName=Root}"
                Style="{StaticResource SectionSecondaryTextBlockStyle}"
                Text="{Binding Eyebrow, ElementName=Root}" />
            <TextBlock
                Style="{StaticResource SectionTitleTextBlockStyle}"
                Text="{Binding Title, ElementName=Root}" />
            <TextBlock
                Visibility="{Binding HasDescription, ElementName=Root}"
                Style="{StaticResource SectionSecondaryTextBlockStyle}"
                Text="{Binding Description, ElementName=Root}" />
        </StackPanel>
        <ContentPresenter
            Grid.Column="1"
            VerticalAlignment="Center"
            Content="{Binding ActionContent, ElementName=Root}" />
    </Grid>
</UserControl>
