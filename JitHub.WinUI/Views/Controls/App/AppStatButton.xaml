<UserControl
    x:Class="JitHub.WinUI.Views.Controls.App.AppStatButton"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="using:JitHub.WinUI.Views.Controls.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Button
        Style="{StaticResource AppStatButtonStyle}"
        Command="{Binding Command, ElementName=Root}"
        AutomationProperties.AutomationId="{Binding AutomationId, ElementName=Root}">
        <Button.Resources>
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource AppSurfaceSubtleColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{ThemeResource AppOutlineStrongColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{ThemeResource AppOutlineStrongColor}" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource AppInkColor}" />
        </Button.Resources>
        <Grid
            ColumnSpacing="8"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <app:AppIcon
                VerticalAlignment="Center"
                IconBrush="{Binding IconForeground, ElementName=Root}"
                IconKind="{Binding IconKind, ElementName=Root}"
                IconSize="18"
                IsSelected="{Binding IsSelected, ElementName=Root}"
                SelectedBrush="{Binding SelectedIconForeground, ElementName=Root}" />
            <TextBlock
                Grid.Column="1"
                Margin="0,1,0,0"
                VerticalAlignment="Center"
                FontFamily="{ThemeResource AppUiFontFamily}"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppInkBrush}"
                Text="{Binding ValueText, ElementName=Root}" />
        </Grid>
    </Button>
</UserControl>
