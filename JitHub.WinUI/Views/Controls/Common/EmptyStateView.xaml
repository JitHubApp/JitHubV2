<UserControl
    x:Class="JitHub.WinUI.Views.Controls.Common.EmptyStateView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        MaxWidth="520"
        HorizontalAlignment="Left"
        Padding="0"
        Background="Transparent"
        BorderThickness="0"
        CornerRadius="0">
        <StackPanel
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Spacing="6">
            <TextBlock
                HorizontalAlignment="Left"
                Style="{StaticResource SectionTitleTextBlockStyle}"
                Text="{Binding Title, ElementName=Root}" />
            <TextBlock
                HorizontalAlignment="Left"
                TextAlignment="Left"
                Style="{StaticResource SectionSecondaryTextBlockStyle}"
                Text="{Binding Description, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>


