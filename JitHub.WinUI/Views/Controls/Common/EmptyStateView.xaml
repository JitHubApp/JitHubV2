<UserControl
    x:Class="JitHub.WinUI.Views.Controls.Common.EmptyStateView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="8">
        <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource SectionTitleTextBlockStyle}"
            Text="{Binding Title, ElementName=Root}" />
        <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource SectionSecondaryTextBlockStyle}"
            Text="{Binding Description, ElementName=Root}" />
    </StackPanel>
</UserControl>


