<UserControl
    x:Class="JitHub.WinUI.Views.Controls.Common.RepoLabel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Border
        CornerRadius="{ThemeResource AppRadiusSmall}"
        Padding="8,0"
        Height="22"
        VerticalAlignment="Center"
        BorderBrush="{ThemeResource AppOutlineBrush}"
        BorderThickness="1"
        Width="auto"
        Background="{x:Bind GetBackgroundBrush(Label), Mode=OneWay}"
        ToolTipService.ToolTip="{x:Bind GetDescription(Label), Mode=OneWay}">
        <TextBlock
            VerticalAlignment="Center"
            Style="{StaticResource ListItemSecondaryTextBlockStyle}"
            Height="16"
            FontSize="12"
            LineHeight="16"
            LineStackingStrategy="BlockLineHeight"
            TextAlignment="Center"
            Margin="0"
            Text="{x:Bind GetName(Label), Mode=OneWay}"
            Foreground="{x:Bind GetForegroundBrush(Label), Mode=OneWay}"/>
    </Border>
</UserControl>

