<UserControl
    x:Class="JitHub.WinUI.Views.Controls.Common.MarkdownForm"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:JitHub.WinUI.ViewModels"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <viewmodels:MarkdownFormViewModel x:Name="ViewModel" />
    </UserControl.DataContext>
    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <controls:Segmented
            Grid.Row="0"
            HorizontalAlignment="Left"
            AutomationProperties.AutomationId="MarkdownModeSegmented"
            SelectedIndex="0"
            SelectionChanged="BodyModeSegmented_SelectionChanged"
            SelectionMode="Single">
            <controls:SegmentedItem Content="Write" />
            <controls:SegmentedItem Content="Preview" />
        </controls:Segmented>

        <Grid
            Grid.Row="1"
            Padding="{x:Bind FormPadding, Mode=OneWay}">
            <controls:SwitchPresenter
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Value="{x:Bind ViewModel.SelectedBodyView, Mode=OneWay}">
                <controls:Case Value="Write">
                    <TextBox
                        Style="{StaticResource AppTextBoxStyle}"
                        AcceptsReturn="True"
                        Height="{x:Bind EditorHeight, Mode=OneWay}"
                        MinHeight="{x:Bind EditorHeight, Mode=OneWay}"
                        Padding="12"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Text="{x:Bind Text, Mode=TwoWay}"
                        TextChanged="TextBox_TextChanged"
                        TextWrapping="Wrap" />
                </controls:Case>
                <controls:Case Value="Preview">
                    <Border
                        Height="{x:Bind EditorHeight, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        MinHeight="{x:Bind EditorHeight, Mode=OneWay}"
                        Padding="12"
                        Background="{ThemeResource AppSurfaceBrush}"
                        BorderBrush="{ThemeResource AppOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource AppRadiusMedium}"
                        VerticalAlignment="Top">
                        <common:MarkdownViewer
                            BaseUrl="https://github.com/"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Text="{x:Bind Text, Mode=OneWay}" />
                    </Border>
                </controls:Case>
            </controls:SwitchPresenter>
        </Grid>
        <ContentPresenter
            x:Name="ActionContentPresenter"
            Grid.Row="2"
            Content="{Binding ActionContent, ElementName=Root}" />
    </Grid>
</UserControl>


