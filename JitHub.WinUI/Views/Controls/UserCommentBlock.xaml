<UserControl
    x:Class="JitHub.WinUI.Views.Controls.UserCommentBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JitHub.WinUI.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:userviewmodels="using:JitHub.WinUI.ViewModels.UserViewModel"
    d:DesignHeight="300"
    d:DesignWidth="400"
    Loaded="UserCommentBlock_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" VerticalAlignment="Top">
            <common:Avatar
                Margin="0,0,8,0"
                ShowLogin="False"
                Size="{x:Bind Size, Mode=OneWay}"
                Url="{x:Bind ViewModel.Commenter.AvatarUrl, Mode=OneWay}" />
        </Grid>
        <common:CommentBlock Grid.Column="1">
            <common:CommentBlock.HeaderContent>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SectionSecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppInkMutedBrush}">
                        <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.Commenter.Login, Mode=OneWay}" />
                        <Run Text="{x:Bind ViewModel.CreatedAt, Mode=OneWay}" />
                    </TextBlock>
                    <Grid Grid.Column="1" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <common:EmojiPanelButton ViewModel="{x:Bind ViewModel.EmojiPanelViewModel, Mode=OneWay}" />
                        <Button
                            Grid.Column="1"
                            Margin="0"
                            Padding="4,2"
                            Style="{StaticResource AppToolbarButtonStyle}">
                            <FontIcon FontFamily="{StaticResource SegoeFluentIcons}" Glyph="&#xE712;" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                    <MenuFlyoutItem
                                        x:Name="CopyLink"
                                        Command="{x:Bind ViewModel.CopyLinkMenuItem.Command, Mode=OneWay}"
                                        Text="{x:Bind ViewModel.CopyLinkMenuItem.Text, Mode=OneWay}" />
                                    <MenuFlyoutItem
                                        x:Name="QuoteReply"
                                        Command="{x:Bind ViewModel.QuoteReplyMenuItem.Command, Mode=OneWay}"
                                        CommandParameter="{x:Bind ViewModel.QuoteReplyMenuItem.Parameter, Mode=OneWay}"
                                        Text="{x:Bind ViewModel.QuoteReplyMenuItem.Text, Mode=OneWay}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </Grid>
            </common:CommentBlock.HeaderContent>
            <common:CommentBlock.BodyContent>
                <Grid Padding="8">
                    <StackPanel Spacing="8">
                        <common:MarkdownViewer
                            BaseUrl="https://github.com/"
                            SurfaceColorToken="AppCanvasRaised"
                            Text="{x:Bind ViewModel.Body, Mode=OneWay}" />
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.HasReaction, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <common:EmojiPanelButton ViewModel="{x:Bind ViewModel.EmojiPanelViewModel, Mode=OneWay}" />
                            <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.ReactionWithUsers, Mode=OneWay}">
                                <muxc:ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="userviewmodels:ReactionWithUsers">
                                        <Grid>
                                            <common:EmojiButton
                                                Reaction="{x:Bind Type, Mode=OneWay}"
                                                ReactionCommand="{x:Bind ReactionCommand, Mode=OneWay}"
                                                ReactionCount="{x:Bind Users.Count, Mode=OneWay}"
                                                ShowReactionCount="True"
                                                Users="{x:Bind Users, Mode=OneWay}"
                                                Voted="{x:Bind Voted, Mode=OneWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </muxc:ItemsRepeater.ItemTemplate>
                                <muxc:ItemsRepeater.Layout>
                                    <muxc:StackLayout Orientation="Horizontal" Spacing="8" />
                                </muxc:ItemsRepeater.Layout>
                            </muxc:ItemsRepeater>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </common:CommentBlock.BodyContent>
        </common:CommentBlock>
    </Grid>
</UserControl>




