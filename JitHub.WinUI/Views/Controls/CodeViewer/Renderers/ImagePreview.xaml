<UserControl
    x:Class="JitHub.WinUI.Views.Controls.CodeViewer.Renderers.ImagePreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource AppCanvasBrush}"
    d:DesignHeight="500"
    d:DesignWidth="700"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Zoomable image  -->
        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Auto"
            MaxZoomFactor="8"
            MinZoomFactor="0.1"
            VerticalScrollBarVisibility="Auto"
            ZoomMode="Enabled">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <Image
                    x:Name="PreviewImage"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
                <TextBlock
                    x:Name="ErrorText"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource AppInkMutedBrush}"
                    Text="Unable to render this image."
                    Visibility="Collapsed" />
            </Grid>
        </ScrollViewer>

        <!--  Footer with metadata  -->
        <Border
            Grid.Row="1"
            Padding="12,6"
            Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppOutlineBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                x:Name="FooterText"
                Foreground="{ThemeResource AppInkMutedBrush}"
                Style="{StaticResource SectionSecondaryTextBlockStyle}" />
        </Border>

    </Grid>

</UserControl>
