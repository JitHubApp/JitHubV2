<UserControl
    x:Class="JitHub.WinUI.Views.Controls.CodeViewer.Renderers.YamlPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codeviewer="using:JitHub.WinUI.Views.Controls.CodeViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource AppCanvasBrush}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <codeviewer:CodeEditorControl
        x:Name="Editor"
        IsReadOnlyEditor="True"
        LanguageId="yaml" />

</UserControl>
