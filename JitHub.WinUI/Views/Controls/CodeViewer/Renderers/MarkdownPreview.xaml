<UserControl
    x:Class="JitHub.WinUI.Views.Controls.CodeViewer.Renderers.MarkdownPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codeviewer="using:JitHub.WinUI.Views.Controls.CodeViewer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource AppCanvasBrush}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!--  Light theme  -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="InlineCodeBackground" Color="#E8E3D8" />
                    <SolidColorBrush x:Key="InlineCodeForeground" Color="#223127" />
                    <SolidColorBrush x:Key="CodeBlockBackground" Color="#EDE8DD" />
                    <SolidColorBrush x:Key="CodeBlockForeground" Color="#223127" />
                    <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="#3E7B64" />
                </ResourceDictionary>
                <!--  Dark theme (also applied as Default for dark-mode fallback)  -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="InlineCodeBackground" Color="#303830" />
                    <SolidColorBrush x:Key="InlineCodeForeground" Color="#C7CDBF" />
                    <SolidColorBrush x:Key="CodeBlockBackground" Color="#1C221C" />
                    <SolidColorBrush x:Key="CodeBlockForeground" Color="#C7CDBF" />
                    <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="#77B59A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="InlineCodeBackground" Color="#303830" />
                    <SolidColorBrush x:Key="InlineCodeForeground" Color="#C7CDBF" />
                    <SolidColorBrush x:Key="CodeBlockBackground" Color="#1C221C" />
                    <SolidColorBrush x:Key="CodeBlockForeground" Color="#C7CDBF" />
                    <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="#77B59A" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Padding="8,6"
            Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppOutlineBrush}"
            BorderThickness="0,0,0,1">
            <controls:Segmented
                x:Name="ViewModeSegmented"
                HorizontalAlignment="Left"
                SelectionChanged="ViewModeSegmented_SelectionChanged"
                SelectionMode="Single">
                <controls:SegmentedItem Content="Rich" />
                <controls:SegmentedItem Content="Plain" />
            </controls:Segmented>
        </Border>

        <!--  Body  -->
        <Grid Grid.Row="1">

            <!--  Rich: MarkdownTextBlock  -->
            <ScrollViewer
                x:Name="RichPanel"
                Padding="16"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                SizeChanged="RichPanel_SizeChanged"
                Visibility="Visible">
                <controls:MarkdownTextBlock
                    x:Name="RichMarkdown"
                    Text="{x:Bind ViewModel.Text, Mode=OneWay}"
                    Foreground="{ThemeResource AppInkBrush}"
                    MaxWidth="860"
                    HorizontalAlignment="Center" />
            </ScrollViewer>

            <!--  Plain: raw code editor  -->
            <codeviewer:CodeEditorControl
                x:Name="PlainPanel"
                IsReadOnlyEditor="True"
                LanguageId="markdown"
                Text="{x:Bind ViewModel.Text, Mode=OneWay}"
                Visibility="Collapsed" />

        </Grid>

    </Grid>

</UserControl>
