<UserControl
    x:Class="JitHub.WinUI.Views.Controls.CodeViewer.Renderers.MarkdownPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codeviewer="using:JitHub.WinUI.Views.Controls.CodeViewer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource AppCanvasBrush}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources />

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Padding="8,6"
            Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppOutlineBrush}"
            BorderThickness="0,0,0,1">
            <controls:Segmented
                x:Name="ViewModeSegmented"
                HorizontalAlignment="Left"
                SelectionChanged="ViewModeSegmented_SelectionChanged"
                SelectionMode="Single">
                <controls:SegmentedItem Content="Rich" />
                <controls:SegmentedItem Content="Plain" />
            </controls:Segmented>
        </Border>

        <!--  Body  -->
        <Grid Grid.Row="1">

            <!--  Rich: MarkdownTextBlock  -->
            <ScrollViewer
                x:Name="RichPanel"
                Padding="16"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                Visibility="Visible">
                <controls:MarkdownTextBlock
                    x:Name="RichMarkdown"
                    MaxWidth="860"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource AppInkBrush}" />
            </ScrollViewer>

            <!--  Plain: raw code editor  -->
            <codeviewer:CodeEditorControl
                x:Name="PlainPanel"
                IsReadOnlyEditor="True"
                LanguageId="markdown"
                Text="{x:Bind ViewModel.Text, Mode=OneWay}"
                Visibility="Collapsed" />

        </Grid>

    </Grid>

</UserControl>
