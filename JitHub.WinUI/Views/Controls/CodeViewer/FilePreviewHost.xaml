<UserControl
    x:Class="JitHub.WinUI.Views.Controls.CodeViewer.FilePreviewHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:JitHub.WinUI.ViewModels.CodeViewer"
    xmlns:renderers="using:JitHub.WinUI.Views.Controls.CodeViewer.Renderers"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource AppCanvasBrush}">

    <Grid x:Name="Root">
        <Grid x:Name="LoadingState"
              Visibility="Collapsed"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <muxc:ProgressRing IsActive="True" Width="40" Height="40" />
        </Grid>

        <Border x:Name="ErrorState"
                Visibility="Collapsed"
                MaxWidth="520"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppOutlineBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource AppRadiusLarge}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                           Text="Unable to load this file." />
                <TextBlock x:Name="ErrorMessageText"
                           Style="{StaticResource SectionSecondaryTextBlockStyle}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Grid x:Name="EmptyState"
              Visibility="Visible"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE8A5;" FontSize="32" Foreground="{ThemeResource AppInkMutedBrush}" />
                <TextBlock Style="{StaticResource SectionSecondaryTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Text="Select a file to preview" />
            </StackPanel>
        </Grid>

        <ContentPresenter x:Name="RendererHost" />
    </Grid>
</UserControl>
