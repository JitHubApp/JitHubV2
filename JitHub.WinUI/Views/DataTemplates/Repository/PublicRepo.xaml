<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appcontrols="using:JitHub.WinUI.Views.Controls.App"
    xmlns:common="using:JitHub.WinUI.Views.Controls.Common"
    xmlns:models="using:JitHub.Models">
    <DataTemplate x:Key="PublicRepo">
        <Button
            Margin="0,0,4,0"
            Style="{StaticResource AppQuietButtonStyle}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding DetailNavigationCommand}">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <appcontrols:AppIcon
                        VerticalAlignment="Center"
                        IconBrush="{ThemeResource AppInkMutedBrush}"
                        IconKind="PublicRepository"
                        IconSize="16" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                </StackPanel>
            </Grid>
        </Button>
    </DataTemplate>
    <DataTemplate x:Key="PublicRepoSearchResult">
        <Button
            Style="{StaticResource AppQuietButtonStyle}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            Command="{Binding DetailNavigationCommand, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <appcontrols:AppIcon
                    Grid.Column="0"
                    Margin="0,5,5,0"
                    VerticalAlignment="Top"
                    IconBrush="{ThemeResource AppInkMutedBrush}"
                    IconKind="PublicRepository"
                    IconSize="16" />
                <StackPanel Grid.Column="1">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="{Binding FullName, Mode=OneWay}" />
                    <TextBlock Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <appcontrols:AppIcon
                            VerticalAlignment="Center"
                            IconBrush="{ThemeResource AppWarmAccentBrush}"
                            IconKind="Star"
                            IconSize="13" />
                        <TextBlock VerticalAlignment="Bottom" Text="{Binding StargazersCount, Converter={StaticResource NumberToKizedStringConverter}, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Button>
    </DataTemplate>
    <DataTemplate x:Key="SelectablePublicRepo">
        <Border Style="{ThemeResource Container}">
            <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <appcontrols:AppIcon
                        Grid.Column="0"
                        Margin="0,5,5,0"
                        VerticalAlignment="Top"
                        IconBrush="{ThemeResource AppInkMutedBrush}"
                        IconKind="PublicRepository"
                        IconSize="16" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding FullName, Mode=OneWay}" />
                        <TextBlock Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <appcontrols:AppIcon
                                IconBrush="{ThemeResource AppWarmAccentBrush}"
                                IconKind="Star"
                                IconSize="14" />
                            <TextBlock Text="{Binding StargazersCount, Converter={StaticResource NumberToKizedStringConverter}, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </CheckBox>
        </Border>
    </DataTemplate>
</ResourceDictionary>




