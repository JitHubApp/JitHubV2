<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="AppDisplayFontFamily">ms-appx:///Assets/Fonts/InstrumentSerif-Regular.ttf#Instrument Serif</FontFamily>
    <FontFamily x:Key="AppUiFontFamily">ms-appx:///Assets/Fonts/JetBrainsMono-Variable.ttf#JetBrains Mono</FontFamily>
    <FontFamily x:Key="AppBodyFontFamily">Segoe UI</FontFamily>

    <x:Double x:Key="AppDisplay1FontSize">36</x:Double>
    <x:Double x:Key="AppDisplay2FontSize">28</x:Double>
    <x:Double x:Key="AppTitleFontSize">22</x:Double>
    <x:Double x:Key="AppBodyFontSize">15</x:Double>
    <x:Double x:Key="AppMetaFontSize">13</x:Double>
</ResourceDictionary>
