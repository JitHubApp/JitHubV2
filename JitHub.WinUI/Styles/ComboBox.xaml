<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextControlHeaderForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlHeaderForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />

    <Style
        x:Key="ComboBox"
        BasedOn="{StaticResource DefaultComboBoxStyle}"
        TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="AppTextBoxStyle"
        TargetType="TextBox"
        BasedOn="{StaticResource DefaultTextBoxStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="AppRichEditBoxStyle"
        TargetType="RichEditBox"
        BasedOn="{StaticResource DefaultRichEditBoxStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppBodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="120" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style
        x:Key="AppAutoSuggestBoxStyle"
        TargetType="AutoSuggestBox"
        BasedOn="{StaticResource DefaultAutoSuggestBoxStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="ShellSearchAutoSuggestBoxStyle"
        TargetType="AutoSuggestBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AppBodyFontSize}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
    </Style>

    <Style
        x:Key="ShellSearchTextBoxStyle"
        TargetType="TextBox"
        BasedOn="{StaticResource AppTextBoxStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,9,0,0" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AppBodyFontSize}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource ComboBox}" />
    <Style TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}" />
    <Style TargetType="RichEditBox" BasedOn="{StaticResource AppRichEditBoxStyle}" />
    <Style TargetType="AutoSuggestBox" BasedOn="{StaticResource AppAutoSuggestBoxStyle}" />
</ResourceDictionary>
