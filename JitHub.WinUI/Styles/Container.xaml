<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="Container" TargetType="Border">
        <Setter Property="Padding" Value="{ThemeResource AppCardPadding}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="Background" Value="{ThemeResource AppCanvasRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="PlainContainer" TargetType="Border">
        <Setter Property="Padding" Value="{ThemeResource AppCardPadding}" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="ActionPanel" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Spacing" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>
    <Style x:Key="ActivityContainer" TargetType="Border">
        <Setter Property="Padding" Value="12" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
    </Style>
    <Style x:Key="SectionCardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="{ThemeResource AppCardPadding}" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusLarge}" />
    </Style>
</ResourceDictionary>
