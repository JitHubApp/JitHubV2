<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BorderGray" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="TitleBlue" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="NewButtonBackground" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="NewButtonHovered" Color="{ThemeResource AppAccentHoverColor}" />
</ResourceDictionary>
