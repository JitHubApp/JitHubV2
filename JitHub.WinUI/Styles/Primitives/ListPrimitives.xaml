<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="ListViewItem">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusSmall}" />
    </Style>
    <Style TargetType="ProgressRing">
        <Setter Property="Foreground" Value="{ThemeResource AppAccentBrush}" />
    </Style>
</ResourceDictionary>
