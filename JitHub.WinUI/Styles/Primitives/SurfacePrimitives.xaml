<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="SurfaceStrokeColorDefaultBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="SurfaceStrokeColorFlyoutBrush" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="SmokeFillColorDefaultBrush" Color="#88000000" />
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="{ThemeResource AppCanvasRaisedColor}" />
    <SolidColorBrush x:Key="ExpanderContentBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="SystemColorGrayTextBrush" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="SystemControlForegroundChromeGrayBrush" Color="{ThemeResource AppInkMutedColor}" />
    <StaticResource x:Key="SystemRevealChromeGrayColor" ResourceKey="AppInkMutedColor" />
    <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="{ThemeResource AppInkColor}" />
</ResourceDictionary>
