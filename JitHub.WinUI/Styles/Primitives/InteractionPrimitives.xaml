<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <!--
        A single interaction bridge for WinUI's built-in resource keys.
        App pages should consume semantic JitHub resources, but default templates still
        ask for these names when they enter hover/pressed/selected/open states.
    -->

    <!--  Core WinUI aliases  -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ControlFillColorTransparent" Color="Transparent" />
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ControlAltFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="ControlStrongFillColorDisabledBrush" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ControlSolidFillColorDefaultBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrushPointerOver" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentTertiaryBrush" Color="{ThemeResource AppAccentPressedColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDisabledBrush" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceStrokeColorFlyoutBrush" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="SystemControlTransparentRevealBackgroundBrush" Color="Transparent" />
    <SolidColorBrush x:Key="SystemControlTransparentRevealBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{ThemeResource AppAccentPressedColor}" />
    <SolidColorBrush x:Key="AccentAAFillColorDefaultBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="{ThemeResource AppAccentPressedColor}" />
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{ThemeResource AppAccentColor}" Opacity="0.45" />
    <StaticResource x:Key="TextOnAccentAAFillColorPrimary" ResourceKey="AppAccentForegroundColor" />
    <SolidColorBrush x:Key="TextOnAccentAAFillColorPrimaryBrush" Color="{ThemeResource AppAccentForegroundColor}" />
    <SolidColorBrush x:Key="FocusStrokeColorOuterBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="FocusStrokeColorInnerBrush" Color="{ThemeResource AppSurfaceColor}" />

    <!-- Keep stubborn WinUI template accents inside the JitHub palette. -->
    <StaticResource x:Key="SystemAccentColor" ResourceKey="AppAccentColor" />
    <StaticResource x:Key="SystemAccentColorLight1" ResourceKey="AppAccentHoverColor" />
    <StaticResource x:Key="SystemAccentColorLight2" ResourceKey="AppAccentHoverColor" />
    <StaticResource x:Key="SystemAccentColorLight3" ResourceKey="AppAccentForegroundColor" />
    <StaticResource x:Key="SystemAccentColorDark1" ResourceKey="AppAccentPressedColor" />
    <StaticResource x:Key="SystemAccentColorDark2" ResourceKey="AppAccentPressedColor" />
    <StaticResource x:Key="SystemAccentColorDark3" ResourceKey="AppAccentPressedColor" />
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="SystemControlHighlightAltAccentBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="{ThemeResource AppAccentPressedColor}" Opacity="0.24" />
    <SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="{ThemeResource AppAccentColor}" Opacity="0.38" />
    <SolidColorBrush x:Key="SystemControlHighlightListAccentHighBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="SystemControlDisabledAccentBrush" Color="{ThemeResource AppHairlineColor}" />

    <!--  Text controls  -->
    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource AppCanvasRaisedColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="{ThemeResource AppAccentColor}" Opacity="0.45" />
    <SolidColorBrush x:Key="TextControlButtonBackground" Color="Transparent" />
    <SolidColorBrush x:Key="TextControlButtonBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="TextControlButtonBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="TextControlButtonForeground" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="TextControlButtonForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlButtonForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="TextControlButtonBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="TextControlButtonBorderBrushPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="TextControlButtonBorderBrushPressed" Color="Transparent" />

    <!--  Combo boxes and dropdown picker popups  -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{ThemeResource AppCanvasRaisedColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{ThemeResource AppOutlineColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{ThemeResource AppOutlineStrongColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled" Color="{ThemeResource AppHairlineColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{ThemeResource AppOutlineStrongColor}" />
    <Thickness x:Key="ComboBoxDropdownBorderThickness">1</Thickness>
    <Thickness x:Key="ComboBoxDropdownBorderPadding">6</Thickness>
    <Thickness x:Key="ComboBoxDropdownContentMargin">0</Thickness>
    <CornerRadius x:Key="ComboBoxDropDownButtonBackgroundCornerRadius">5</CornerRadius>
    <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownGlyphForegroundPressed" Color="{ThemeResource AppInkColor}" />

    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedUnfocused" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedUnfocused" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedDisabled" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushPressed" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelected" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedUnfocused" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedPressed" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelected" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedUnfocused" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedPointerOver" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushPressed" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelected" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedUnfocused" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedPressed" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemPillFillBrush" Color="{ThemeResource AppAccentColor}" />
    <Thickness x:Key="ComboBoxItemThemePadding">12,8</Thickness>
    <Thickness x:Key="ComboBoxItemRevealThemePadding">12,8</Thickness>

    <Style TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusSmall}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  Menus and context flyouts  -->
    <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="{ThemeResource AppOutlineStrongColor}" />
    <Thickness x:Key="MenuFlyoutPresenterThemePadding">6</Thickness>
    <Thickness x:Key="MenuFlyoutPresenterBorderThemeThickness">1</Thickness>
    <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="MenuFlyoutItemBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemBackgroundSubMenuOpened" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemForegroundSubMenuOpened" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemChevron" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemChevronPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemChevronPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemChevronSubMenuOpened" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="MenuFlyoutSubItemChevronDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ToggleMenuFlyoutItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />

    <!--  Lists, suggestion rows, and selection surfaces  -->
    <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedDisabled" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="ListViewItemForeground" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundSelectedPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="ListViewItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="ListViewItemFocusBorderBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="ListViewItemFocusSecondaryBorderBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPointerOverBrush" Color="{ThemeResource AppAccentHoverColor}" />
    <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPressedBrush" Color="{ThemeResource AppAccentPressedColor}" />
    <SolidColorBrush x:Key="ListViewItemSelectionIndicatorDisabledBrush" Color="{ThemeResource AppHairlineColor}" />
    <CornerRadius x:Key="ListViewItemCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="ListViewItemSelectionIndicatorCornerRadius">3</CornerRadius>

    <!--  Pivot/segmented-style navigation  -->
    <FontFamily x:Key="PivotHeaderItemFontFamily">ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono</FontFamily>
    <x:Double x:Key="PivotHeaderItemFontSize">13</x:Double>
    <Thickness x:Key="PivotHeaderItemMargin">12,8</Thickness>
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundUnselected" Color="Transparent" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundUnselectedPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundUnselectedPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundSelected" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundSelectedPointerOver" Color="{ThemeResource AppSurfaceSubtleColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundSelectedPressed" Color="{ThemeResource AppCanvasInsetColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselected" Color="{ThemeResource AppInkMutedColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselectedPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundUnselectedPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundSelected" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundSelectedPointerOver" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundSelectedPressed" Color="{ThemeResource AppInkColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemForegroundDisabled" Color="{ThemeResource AppInkSubtleColor}" />
    <SolidColorBrush x:Key="PivotHeaderItemSelectedPipeFill" Color="{ThemeResource AppAccentColor}" />

    <Style TargetType="Pivot">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="controls:Segmented">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkBrush}" />
        <Setter Property="Background" Value="{ThemeResource AppCanvasInsetBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusMedium}" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style TargetType="controls:SegmentedItem">
        <Setter Property="FontFamily" Value="{ThemeResource AppUiFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppInkMutedBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{ThemeResource AppRadiusSmall}" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Height" Value="30" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SegmentedItem">
                    <Grid MinHeight="{TemplateBinding MinHeight}" Height="{TemplateBinding Height}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppSurfaceBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppCanvasRaisedBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineStrongBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppSurfaceBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOverSelected">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppSurfaceBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineStrongBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppSurfaceBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineStrongBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PressedSelected">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppCanvasRaisedBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineStrongBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource AppCanvasRaisedBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource AppOutlineStrongBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppInkBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedDisabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <Setter Target="FocusVisual.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <Border
                            x:Name="FocusVisual"
                            BorderBrush="{ThemeResource AppAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            IsHitTestVisible="False"
                            Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
